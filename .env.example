# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Придумайте любую случайную строку — используется для защиты вебхука и /api/setup
TELEGRAM_WEBHOOK_SECRET=

# POSTGRES_URL и т.д. добавляются автоматически, когда в Vercel подключаете Storage → Postgres
# POSTGRES_URL=

# Необязательно: тарифы доставки (значения по умолчанию уже такие)
CITY_DELIVERY_FEE=1500
OUTSIDE_CITY_EXTRA_FEE=500

# Необязательно: часовой пояс для суточного среза (по умолчанию Asia/Almaty)
TIMEZONE=Asia/Almaty
